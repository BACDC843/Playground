# GoHighLevel credentials
GHL_API_KEY=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GHL_LOCATION_ID=xxxxxxxxxxxxxxxxxxxxxx

# Secret token — clients must send: Authorization: Bearer <this value>
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MCP_AUTH_TOKEN=your-secret-token-here

# Port (Railway sets this automatically — only needed for local testing)
PORT=3000
